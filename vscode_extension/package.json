{
  "name": "forgesdlc",
  "displayName": "forgeSDLC — SDLC Intelligence Layer",
  "description": "Requirements, architecture, memory, security, and monitoring for Cursor, Claude Code, and Copilot",
  "version": "0.1.0",
  "publisher": "Akash-1512",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["mcp", "sdlc", "ai", "architecture", "cursor", "copilot"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "forgesdlc.addToMCP",
        "title": "forgeSDLC: Add to MCP Config"
      },
      {
        "command": "forgesdlc.openPanel",
        "title": "forgeSDLC: Open Companion Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forgesdlc",
          "title": "forgeSDLC",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "forgesdlc": [
        {
          "id": "forgesdlc.projectView",
          "name": "Project",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "jest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts", "**/*.spec.ts"]
  }
}