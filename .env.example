# forgeSDLC environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Database (PostgreSQL — required) ──────────────────────────────────────────
# Run local: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=forgesdlc --name forgesdlc-db postgres:16
DATABASE_URL=postgresql+asyncpg://postgres:forgesdlc@localhost:5432/forgesdlc

# ── Session security ──────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── LLM API keys (BYOK — stored in OS keychain via BYOKManager, not here) ────
# These are only used for local dev. In production use BYOKManager.save_key().
OPENAI_API_KEY=
GROQ_API_KEY=

# ── ToolRouter configuration ──────────────────────────────────────────────────
# Cursor Background Agent (requires ToS review — see legal/cursor_api_review.md)
CURSOR_API_KEY=
CURSOR_API_VERIFIED=false

# Devin API
DEVIN_API_KEY=

# ── CI keyring backend (Linux GitHub Actions only) ────────────────────────────
# PYTHON_KEYRING_BACKEND=keyrings.alt.PlaintextKeyring